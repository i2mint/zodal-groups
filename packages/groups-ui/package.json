{
  "name": "@zodal/groups-ui",
  "version": "0.1.0",
  "description": "Headless UI layer for zodal-groups: view descriptors, drag-intent model, renderer registry",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "publishConfig": { "access": "public" },
  "files": ["dist"],
  "scripts": { "build": "tsup", "test": "vitest run", "typecheck": "tsc --noEmit" },
  "peerDependencies": { "@zodal/groups-core": "^0.1.0" },
  "devDependencies": {
    "@zodal/groups-core": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
